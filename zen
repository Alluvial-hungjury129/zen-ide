#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import subprocess
import sys

project_dir = os.path.dirname(os.path.realpath(__file__))
src_dir = os.path.join(project_dir, 'src')

env = os.environ.copy()
env['PYTHONPATH'] = project_dir + ':' + env.get('PYTHONPATH', '')
env['PYTHON_JIT'] = '1'

# macOS: Homebrew libs need DYLD_FALLBACK_LIBRARY_PATH for GLib typelib lookups
if sys.platform == 'darwin' and not env.get('DYLD_FALLBACK_LIBRARY_PATH'):
    brew_lib = '/opt/homebrew/lib'
    if not os.path.isdir(brew_lib):
        brew_lib = '/usr/local/lib'  # Intel Mac fallback
    if os.path.isdir(brew_lib):
        env['DYLD_FALLBACK_LIBRARY_PATH'] = brew_lib

venv_python = os.path.join(project_dir, '.venv', 'bin', 'python3')

# Launch IDE fully detached — the GUI manages its own lifecycle.
# Don't wait: returns the shell prompt immediately (like `code`, `subl`)
# and avoids terminal-title pollution and freeze-on-quit.
subprocess.Popen(
    [venv_python, os.path.join(src_dir, 'zen_ide_window.py')] + sys.argv[1:],
    env=env,
    stdin=subprocess.DEVNULL,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
